{
  "name": "vue-refx",
  "version": "0.3.0-beta.3",
  "description": "React-style forwarded refs for Vue, implemented as a compiler transform.",
  "license": "MIT",
  "files": [
    "dist",
    "packages"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/runtime.cjs",
  "module": "./dist/runtime.js",
  "types": "./dist/runtime.d.ts",
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./volar": {
      "types": "./dist/volar.d.ts",
      "import": "./dist/volar.js",
      "require": "./dist/volar.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "pnpm --dir playground dev",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "pack:check": "npm --cache ./.npm-cache --registry https://registry.npmjs.org/ pack --dry-run",
    "publish:npm": "node scripts/npm-publish.mjs",
    "release": "bumpp --git-check --no-push --execute \"pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm pack:check\" && pnpm publish:npm && git push --follow-tags",
    "release:version": "bumpp --git-check --no-push",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:playground": "vue-tsc --noEmit -p playground/tsconfig.json"
  },
  "dependencies": {
    "@babel/parser": "^7.26.3",
    "@babel/traverse": "^7.26.4",
    "@babel/types": "^7.26.3",
    "@vue/compiler-dom": "^3.5.13",
    "@vue/compiler-sfc": "^3.5.13",
    "@vue/language-core": "^3.3.7",
    "magic-string": "^0.30.17",
    "unplugin": "^2.1.2"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "catalog:",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10",
    "vue": "catalog:",
    "vue-tsc": "^3.3.7"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
