{
  "name": "vue-forward-ref",
  "version": "0.1.0",
  "description": "React-style forwarded refs for Vue, implemented as a compiler transform.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/runtime.cjs",
  "module": "./dist/runtime.js",
  "types": "./dist/runtime.d.ts",
  "files": [
    "dist",
    "packages"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "pnpm --dir playground dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@babel/parser": "^7.26.3",
    "@babel/traverse": "^7.26.4",
    "@babel/types": "^7.26.3",
    "@vue/compiler-dom": "^3.5.13",
    "@vue/compiler-sfc": "^3.5.13",
    "magic-string": "^0.30.17",
    "unplugin": "^2.1.2"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue": "^3.5.13"
  }
}
